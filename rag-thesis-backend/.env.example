# ============================================================
# ISU Thesis AI Library — backend environment configuration
# Copy to .env and fill in the values. NEVER commit .env.
# ============================================================

# Google Gemini API key (embeddings + LLM synthesis)
GEMINI_API_KEY=your-gemini-api-key

# Supabase project
SUPABASE_URL=https://your-project.supabase.co
# IMPORTANT: use the SERVICE_ROLE key here (the backend bypasses RLS).
# The anon key belongs in the frontend .env only.
SUPABASE_KEY=your-service-role-key

# --- Optional overrides (defaults shown) ---
# GEMINI_CHAT_MODEL=gemini-3.1-flash-lite
# GEMINI_VERDICT_MODEL=gemini-3.1-flash-lite
# GEMINI_EMBED_MODEL=models/gemini-embedding-2
# CORS_ORIGINS=http://localhost:5173,https://thesis.isu.edu.ph
# MAX_UPLOAD_MB=25
# MAX_PDF_PAGES=500
# DUPLICATION_THRESHOLD=0.85
# RETRIEVAL_THRESHOLD=0.30
# RETRIEVAL_MATCH_COUNT=5
# THESIS_EVALUATION_DEPARTMENT=CCSICT
# APP_ENVIRONMENT=development
# Local development may use memory://. Production must use Redis and a shared URI.
# RATE_LIMIT_STORAGE_URI=memory://
# Production example: redis://127.0.0.1:6379/0
# RATE_LIMIT_CHAT=30/minute
# RATE_LIMIT_CHAT_IP=300/minute
# RATE_LIMIT_SCAN=5/minute
# RATE_LIMIT_FOLLOWUP=20/minute
# Production must require aal2 tokens for admin and superadmin API access.
# Production must use true. Local development may use false until MFA is enrolled.
# REQUIRE_PRIVILEGED_MFA=true
# Set only to the hosting platform's known proxy IP/CIDR; never use * publicly.
# FORWARDED_ALLOW_IPS=127.0.0.1

# Optional: Supabase legacy JWT secret (Dashboard -> Project Settings -> API
# -> JWT Settings). When set, rate limiting keys on the verified user id
# instead of the client IP — recommended in production so students behind
# one campus NAT get individual quotas.
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# --- Optional LangSmith tracing (Performance Efficiency evaluation) ---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-key
# LANGCHAIN_PROJECT=isu-thesis-library
# Current LangSmith names (legacy LANGCHAIN_* aliases remain supported)
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your-langsmith-key
# LANGSMITH_PROJECT=isu-thesis-library
# LANGSMITH_HIDE_INPUTS=true
# LANGSMITH_HIDE_OUTPUTS=true

# --- Disposable Supabase integration tests only ---
# Never point these values at the configured application/production project.
# ALLOW_DISPOSABLE_SUPABASE_TESTS=0
# TEST_SUPABASE_URL=https://your-disposable-project.supabase.co
# TEST_SUPABASE_PROJECT_REF=your-disposable-project
# TEST_SUPABASE_ANON_KEY=your-disposable-anon-key
# TEST_SUPABASE_SERVICE_ROLE_KEY=your-disposable-service-role-key
