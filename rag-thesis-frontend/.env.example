# ISU Thesis AI Library — frontend environment
# Copy to .env and fill in. NEVER commit .env.

# Supabase project (ANON key only — never the service_role key)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend API base URL. Leave empty in development (Vite proxies to :8000).
# For production set e.g. https://api.thesis.isu.edu.ph
VITE_API_URL=
